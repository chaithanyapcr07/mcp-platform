{
  "name": "mcp-platform",
  "private": true,
  "version": "0.1.0",
  "description": "Enterprise MCP platform MVP for governed connector, skill, and task operations.",
  "workspaces": [
    "apps/*",
    "packages/*",
    "connectors/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev -w @mcp-platform/api",
    "dev:web": "npm run dev -w @mcp-platform/web",
    "dev:connector": "npm run dev -w @mcp-platform/local-knowledge-base",
    "dev:jira": "npm run dev -w @mcp-platform/jira-connector",
    "create:connector": "node packages/create-mcp-connector/src/index.js",
    "db:generate": "npm run db:generate -w @mcp-platform/api",
    "db:migrate": "npm run db:migrate -w @mcp-platform/api",
    "db:seed": "npm run db:seed -w @mcp-platform/api",
    "test": "npm test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "engines": {
    "node": ">=20"
  }
}
